# UX-preview image: builds Studio in demo mode (no backend, no Keycloak),
# served by a self-contained nginx (SPA fallback, no proxy). Independent of the
# platform — deploy to its own namespace.
FROM node:20-alpine AS builder
WORKDIR /app
COPY package.json ./
RUN npm install
COPY . .
RUN npx vite build --mode demo

FROM nginx:1.27-alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.demo.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
